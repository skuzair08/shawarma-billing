<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- HERO CARD -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/amber">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Naya Order"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/brown_dark"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Order text paste karein ya type karein"
                android:textSize="13sp"
                android:textColor="@color/brown_soft"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ORDER TEXT INPUT CARD -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Order Text"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/brown_dark"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Format: 2 x Regular Shawarma, 1 x Rumali Cheese"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxStrokeColor="@color/amber"
                app:hintTextColor="@color/amber_dark">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/order_text_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="5"
                    android:maxLines="12"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:hint="Yahaan order likho..."
                    android:textSize="14sp"
                    android:textColor="@color/brown_dark" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ACTION BUTTONS -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_process"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="8dp"
        android:text="⚡ Process Order"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/brown_dark"
        app:backgroundTint="@color/amber"
        app:cornerRadius="12dp"
        app:elevation="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sample"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="📋 Sample Load"
            android:textSize="13sp"
            android:textColor="@color/brown_dark"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/amber"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_input"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🗑 Clear"
            android:textSize="13sp"
            android:textColor="@color/error_red"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/error_red"
            app:cornerRadius="10dp" />
    </LinearLayout>

    <!-- TIPS CARD -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/amber_pale">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡 Tips"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/amber_dark"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• Format: 2 x Item Name\n• Multiple items: comma ya newline se separate karein\n• Notes aur comments auto-ignore hote hain\n• Fuzzy matching — typos bhi kaam karte hain!"
                android:textSize="12sp"
                android:textColor="@color/brown_soft"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
